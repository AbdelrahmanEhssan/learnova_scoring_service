# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Railway/API Auth
SCORING_API_KEY=
MITCHY_SERVICE_API_KEY=

# Gemini is disabled by default for Mitchy chat because it caused slow/unstable replies.
# Keep GEMINI_API_KEY if other scripts use it, e.g. document_chunks ingestion.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=12
MITCHY_GEMINI_ENABLED=false

# Provider fallback order used by Mitchy after DB/local/document retrieval.
# Use groq, openrouter, xai/grok in your preferred order.
MITCHY_PROVIDER_ORDER=groq,openrouter,xai
MITCHY_PROVIDER_TIMEOUT_SECONDS=8

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=https://learnova.app
OPENROUTER_APP_NAME=LearNova Mitchy

# xAI / Grok
XAI_API_KEY=
GROK_API_KEY=
XAI_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions

# Document chunks retrieval
MITCHY_DOCUMENT_RETRIEVAL_ENABLED=true
MITCHY_DOCUMENT_RETRIEVAL_LIMIT=5
MITCHY_DOCUMENT_RETRIEVAL_TOPIC_MIN_SCORE=1
MITCHY_DOCUMENT_RETRIEVAL_GLOBAL_MIN_SCORE=3
