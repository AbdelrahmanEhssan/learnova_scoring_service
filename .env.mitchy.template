# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Internal service auth
SCORING_SERVICE_API_KEY=change-this-secret
SCORING_API_KEY=change-this-secret
MITCHY_SERVICE_API_KEY=PASTE_A_LONG_RANDOM_SECRET_HERE

# Mitchy chat completion behavior
# Keep Gemini disabled for chat by default because it caused slow/unstable fallback behavior.
# This does NOT affect separate Gemini embedding scripts used for document_chunks ingestion.
MITCHY_GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite
GEMINI_TIMEOUT_SECONDS=6

# Mitchy document retrieval safety gates
MITCHY_DOCUMENT_RETRIEVAL_ENABLED=true
MITCHY_DOCUMENT_RETRIEVAL_LIMIT=5
MITCHY_DOCUMENT_RETRIEVAL_TOPIC_MIN_SCORE=1
MITCHY_DOCUMENT_RETRIEVAL_GLOBAL_MIN_SCORE=2

# Backup provider order for AI answers after DB/document retrieval.
# Supported values: groq, openrouter, xai, grok
MITCHY_PROVIDER_ORDER=groq,openrouter,xai
MITCHY_PROVIDER_TIMEOUT_SECONDS=8

# Groq fallback provider
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter fallback provider
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=LearNova Mitchy

# xAI/Grok fallback provider
XAI_API_KEY=
GROK_API_KEY=
XAI_MODEL=grok-3-mini
GROK_MODEL=grok-3-mini
XAI_API_URL=https://api.x.ai/v1/chat/completions
